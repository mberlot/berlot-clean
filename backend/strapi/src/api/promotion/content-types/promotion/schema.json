{
  "kind": "collectionType",
  "collectionName": "promotions",
  "info": {
    "singularName": "promotion",
    "pluralName": "promotions",
    "displayName": "Promotion",
    "description": "Time-limited promotional banner with optional product linking"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 150
    },
    "description": {
      "type": "text",
      "maxLength": 500
    },
    "banner": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "mobileBanner": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "linkUrl": {
      "type": "string",
      "maxLength": 255
    },
    "linkLabel": {
      "type": "string",
      "maxLength": 50
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "startDate": {
      "type": "datetime"
    },
    "endDate": {
      "type": "datetime"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "backgroundColor": {
      "type": "string",
      "maxLength": 20
    }
  }
}

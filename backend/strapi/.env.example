# Server
HOST=0.0.0.0
PORT=1337

# Secrets — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=your-api-token-salt
ADMIN_JWT_SECRET=your-admin-jwt-secret
TRANSFER_TOKEN_SALT=your-transfer-token-salt
JWT_SECRET=your-jwt-secret
ENCRYPTION_KEY=your-encryption-key

# Database (SQLite — change for production)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Production: use PostgreSQL
# DATABASE_CLIENT=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=cleaning_cms
# DATABASE_USERNAME=strapi
# DATABASE_PASSWORD=your-password
# DATABASE_SSL=false

# ── Cloudinary upload provider ────────────────────────────────
# Get these from: https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Base folder that already exists in your Cloudinary account.
# All asset subfolders are created under this prefix:
#   berlot-clean/local/products    ← product images (auto-routed)
#   berlot-clean/local/categories  ← category images (auto-routed, 1200×900)
#   berlot-clean/local/brands      ← brand logos (auto-routed)
#   berlot-clean/local/banners     ← promotion banners (auto-routed)
#   berlot-clean/local/hero        ← hero / home-section images (auto-routed)
CLOUDINARY_BASE_FOLDER=berlot-clean/local

# Fallback subfolder used for direct Media Library uploads (no content-type ref).
# Content-type uploads are routed automatically by src/index.js.
CLOUDINARY_ASSET_TYPE=products

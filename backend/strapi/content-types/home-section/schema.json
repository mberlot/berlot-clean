{
  "kind": "singleType",
  "collectionName": "home_sections",
  "info": {
    "singularName": "home-section",
    "pluralName": "home-sections",
    "displayName": "Home Sections",
    "description": "Configurable homepage layout blocks"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "heroBanners": {
      "type": "component",
      "repeatable": true,
      "component": "sections.hero-banner"
    },
    "featuredProductsTitle": {
      "type": "string",
      "default": "Productos Destacados"
    },
    "featuredProducts": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product"
    },
    "promotionalBanners": {
      "type": "component",
      "repeatable": true,
      "component": "sections.promo-banner"
    },
    "categoryHighlights": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category"
    },
    "categoryHighlightsTitle": {
      "type": "string",
      "default": "Categorías"
    },
    "offersTitle": {
      "type": "string",
      "default": "Ofertas del Mes"
    },
    "showOffers": {
      "type": "boolean",
      "default": true
    },
    "offersLimit": {
      "type": "integer",
      "default": 8,
      "min": 1,
      "max": 24
    }
  }
}

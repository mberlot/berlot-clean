# Strapi CMS URL
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Strapi read-only API token (generate in Strapi admin → Settings → API Tokens)
NEXT_PUBLIC_STRAPI_TOKEN=

# Public site URL (used for SEO, sitemap, OpenGraph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Brand name displayed in UI
NEXT_PUBLIC_SITE_NAME=Berlot Clean
